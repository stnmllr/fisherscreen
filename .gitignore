# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
dist/

# uv / venv
.venv/

# Environment — never commit secrets
.env
*.env.local

# Filing-Cache (ADR-4, Tool B Deep Dive — never commit cached EDGAR filings)
cache/

# GCP service account keys only (not all JSON)
*-credentials.json
service-account-*.json
*-sa-key.json

# Claude Code
.claude/

# Editor
.vscode/settings.json
*.swp
*.swo

# OS
Thumbs.db
desktop.ini

# Generated outputs (cold-runs, dossiers, watchlists) — root-anchored so the pattern
# cannot also match the app/output/ source package. An unanchored `output/` excluded
# app/output/ from the Cloud Build context -> ModuleNotFoundError 'app.output' in prod (2026-06-09).
/output/
/output-test/
